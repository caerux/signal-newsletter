# Signal — environment variables
# Copy this file to .env.local and fill in the values for local development.
# In production, set the same keys in the Vercel dashboard.

# --- Supabase ---------------------------------------------------------------
# Found in your Supabase project dashboard under:
#   Settings → Data API  → Project URL and anon/public key
#   Settings → API Keys  → service_role key
# The service role key MUST never ship to the browser; only server code uses it.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...your-anon-key...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key...

# --- RSS ingestion ----------------------------------------------------------
# Shared secret. Requests to POST /api/ingest must send
#   Authorization: Bearer ${INGEST_SECRET}
# unless they come from Vercel Cron. Generate with:
#   openssl rand -base64 32
INGEST_SECRET=
